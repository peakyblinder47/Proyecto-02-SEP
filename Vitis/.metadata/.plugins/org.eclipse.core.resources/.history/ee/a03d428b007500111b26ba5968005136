//Leemos hacia donde apunta el joystick
Direccion JoystickDirection(void){
	//Lectura de los ejes x e y
	int joyx = read_joyx();
	int joyy = read_joyy();

	//Cuando estß bajo un umbral definido, decimos que retorne un "None"
	if(abs(joyx-JOY_CENTER_X)<JOY_UMBRAL && abs(joyy-JOY_CENTER_Y)<JOY_UMBRAL ){
		return DIR_NONE;
	}
	//Cuando el joystick en alg˙n eje supera el umbral,
	//entonces se toma como un movimiento
	//Esto estß basado en cˇdigos del proyecto del grupo 8 2024-2
	//para hacerlo un poco mßs interesante, se usaron los typedef
	if (abs(joyx-JOY_CENTER_X)>JOY_UMBRAL){
		if (joyx-JOY_CENTER_X > 0){
			return DERECHA;
		} else{
			return IZQUIERDA;
		}
	}

	if (abs(joyy-JOY_CENTER_Y)>JOY_UMBRAL){
			if (joyy-JOY_CENTER_Y > 0){
				return ARRIBA;
			} else{
				return ABAJO;
			}
		}
	return DIR_NONE;
}

// Conversiˇn sensor de luz OPT3001
float opt_raw_to_lux(u16 raw)
{
    u16 E = (raw >> 12) & 0xF;
    u16 R = raw & 0xFFF;

    return 0.01f * (float)(1U << E) * (float)R;
}

//funcion sugerida por ia para corregir la impresiˇn de valores float de los sensores
void print_float_2dec(const char* nombre, float valor, const char* unidad)
{
    int entero;
    int decimal;

    entero = (int)valor;

    if (valor < 0) {
        decimal = (int)((entero - valor) * 100.0f);
    } else {
        decimal = (int)((valor - entero) * 100.0f);
    }

    xil_printf("%s = %d.%02d %s", nombre, entero, decimal, unidad);
}


