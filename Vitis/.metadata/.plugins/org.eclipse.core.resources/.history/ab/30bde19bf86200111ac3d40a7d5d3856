		}
}

static void BTN(void){

    u32 botones_previos = LeerBotones();

    while (1) {
        u32 botones_actuales = LeerBotones();
        u32 flancos = botones_actuales & (~botones_previos);

        if (flancos & BTN_START_MASK) {
            xil_printf("BTN0 presionado. Iniciando audio...\r\n");
            return;
        }

        botones_previos = botones_actuales;

        usleep(500);
    }
}

int main(void)
{
    int status;
    const char* SONG_PATH;
    int PATH_INDICE;

    init_platform();

    xil_printf("=== Bienvenido a Guitar Zybo === \n");

    // Inicializar AXI GPIO de botones
    status = XGpio_Initialize(&botones, BTN_GPIO_DEVICE_ID);

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar AXI GPIO\r\n");
        return XST_FAILURE;
    }

    // Configurar GPIO como entrada
    XGpio_SetDataDirection(&botones, BTN_GPIO_CHANNEL, 0xFFFFFFFF);

    // Inicializar audio: monta SD y limpia el buzzer
    status = PLAY_SONG();

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: PLAY_SONG fallo\r\n");
        return XST_FAILURE;
    }


    while (1) {
    	Menu();
    	scanf("%d", &PATH_INDICE);

    	SONG_PATH = ElegirCancion(PATH_INDICE);

    	if (SONH_PATH == NULL){
    		xil_printf("Por favor ingresar opción válida\n");
    		continue;
    	}

    	xil_printf("Escogiste la opción: %d\n", PATH_INDICE);

        // Mantiene alimentada la FIFO mientras el audio está sonando
        ACTUALIZAR_AUDIO();

        usleep(500);
    }

    cleanup_platform();

    return 0;
}
