// ================================================================
// DIRECCIONES SEGUN xparameters.h
// ================================================================

#define BUZZER_BASEADDR XPAR_BUZZER_AXI_0_S00_AXI_BASEADDR

#define BTN_GPIO_DEVICE_ID XPAR_AXI_GPIO_0_DEVICE_ID
#define BTN_GPIO_CHANNEL   1

// Nombre del WAV en la raiz de la SD.
// Usar formato 8.3: maximo 8 caracteres antes del punto.
#define SONG_PATH "SNK8.WAV"

// ================================================================
// Registros BUZZER_AXI
// ================================================================

#define BUZZER_REG_CTRL        0x00
#define BUZZER_REG_DATA        0x04
#define BUZZER_REG_FIFO_FREE   0x04
#define BUZZER_REG_SAMPLES     0x08
#define BUZZER_REG_FIFO_LEVEL  0x0C

#define CTRL_PLAY        (1u << 0)
#define CTRL_CLEAR_FIFO  (1u << 1)
#define CTRL_CLEAR_FLAGS (1u << 2)
#define CTRL_MUTE        (1u << 3)
#define CTRL_PAUSE       (1u << 4)

// ================================================================
// Botones
// ================================================================

#define BTN_START_MASK 0x01  // BTN0
#define BTN_STOP_MASK  0x02  // BTN1

// ================================================================
// Audio esperado
// ================================================================

#define EXPECTED_SAMPLE_RATE 8000
#define EXPECTED_CHANNELS    1
#define EXPECTED_BITS        8

#define AUDIO_BUFFER_BYTES   512  // Debe ser multiplo de 4

// ================================================================
// Volumen
// ================================================================
//
// Unsigned 8-bit PCM:
// 0x80 = 128 = silencio / centro.
//
// VOLUME_NUM / VOLUME_DEN define la amplificacion.
// 1/1 = volumen original
// 2/1 = x2
// 3/1 = x3
// 4/1 = x4
//
// Si distorsiona mucho, baja VOLUME_NUM.

#define VOLUME_NUM 3
#define VOLUME_DEN 2

// ================================================================
// Variables globales
// ================================================================

static FATFS fatfs;
static XGpio BtnGpio;

typedef struct {
    FIL file;
    u32 data_start;
    u32 data_size;
    u32 bytes_sent;
    int active;
    int eof_reached;
} AudioPlayer;

static AudioPlayer player;
static u8 audio_buffer[AUDIO_BUFFER_BYTES];

// ================================================================
// Helpers little-endian para WAV
// ================================================================

static u16 read_le16(const u8 *p)
{
    return (u16)p[0] | ((u16)p[1] << 8);
}

static u32 read_le32(const u8 *p)
{
    return (u32)p[0]
         | ((u32)p[1] << 8)
         | ((u32)p[2] << 16)
         | ((u32)p[3] << 24);
}

// ================================================================
// Aplicar volumen a muestra unsigned 8-bit PCM
// ================================================================

static u8 ApplyVolume(u8 sample)
{
    int centered;
    int amplified;

    /*
     * Audio unsigned 8-bit:
     * 128 es el centro/silencio.
     */
    centered = ((int)sample) - 128;

    /*
     * Amplificación racional:
     * VOLUME_NUM / VOLUME_DEN.
     *
     * Ejemplo:
     * 3/2 = x1.5
     * 2/1 = x2
     */
    amplified = (centered * VOLUME_NUM) / VOLUME_DEN;

    /*
     * Limitamos con margen.
     * En vez de permitir 0 y 255, dejamos 4 y 251.
     * Esto reduce saturación dura en el buzzer.
     */
    if (amplified > 123) {
        amplified = 123;
    } else if (amplified < -124) {
        amplified = -124;
    }

    return (u8)(amplified + 128);
}

// ================================================================
// Acceso al IP BUZZER_AXI
// ================================================================

static void Buzzer_WriteCtrl(u32 value)
{
    Xil_Out32(BUZZER_BASEADDR + BUZZER_REG_CTRL, value);
}

static void Buzzer_Clear(void)
{
    Buzzer_WriteCtrl(0);

    Buzzer_WriteCtrl(CTRL_CLEAR_FIFO | CTRL_CLEAR_FLAGS);

    Buzzer_WriteCtrl(0);
}

static void Buzzer_Play(void)
{
    Buzzer_WriteCtrl(CTRL_PLAY);
}

static void Buzzer_Stop(void)
{
    Buzzer_WriteCtrl(0);
}

static u32 Buzzer_GetFreeWords(void)
{
    return Xil_In32(BUZZER_BASEADDR + BUZZER_REG_FIFO_FREE);
}

static u32 Buzzer_GetFifoLevel(void)
{
    return Xil_In32(BUZZER_BASEADDR + BUZZER_REG_FIFO_LEVEL);
}

static u32 Buzzer_GetStatus(void)
{
    return Xil_In32(BUZZER_BASEADDR + BUZZER_REG_CTRL);
}

static u32 Buzzer_GetSamplesPlayed(void)
{
    return Xil_In32(BUZZER_BASEADDR + BUZZER_REG_SAMPLES);
}

static void Buzzer_WriteAudioWord(u32 word)
{
    /*
     * En el VHDL, cualquier escritura a registro 1, 2 o 3
     * mete una palabra de 32 bits al FIFO.
     *
     * Usamos siempre 0x04 por simplicidad.
     */
    Xil_Out32(BUZZER_BASEADDR + BUZZER_REG_DATA, word);
}

// ================================================================
// Parser WAV robusto
// Busca chunk "fmt " y chunk "data"
// ================================================================

static int Wav_OpenAndValidate(AudioPlayer *p, const char *filename)
{
    FRESULT fr;
    UINT br;
    u8 header[12];

    memset(p, 0, sizeof(AudioPlayer));

    fr = f_open(&p->file, filename, FA_READ);
    if (fr != FR_OK) {
        xil_printf("ERROR: no se pudo abrir %s. FR=%d\r\n", filename, fr);
        return -1;
    }

    fr = f_read(&p->file, header, 12, &br);
    if (fr != FR_OK || br != 12) {
        xil_printf("ERROR: no se pudo leer header WAV\r\n");
        f_close(&p->file);
        return -1;
    }

    if (memcmp(&header[0], "RIFF", 4) != 0 || memcmp(&header[8], "WAVE", 4) != 0) {
        xil_printf("ERROR: archivo no es RIFF/WAVE\r\n");
        f_close(&p->file);
        return -1;
    }

    int found_fmt = 0;
    int found_data = 0;

    u16 audio_format = 0;
    u16 channels = 0;
    u32 sample_rate = 0;
    u16 bits_per_sample = 0;

    while (!found_data) {
        u8 chunk_header[8];

        fr = f_read(&p->file, chunk_header, 8, &br);
        if (fr != FR_OK || br != 8) {
            xil_printf("ERROR: no se encontro chunk data\r\n");
            f_close(&p->file);
            return -1;
        }

        u32 chunk_size = read_le32(&chunk_header[4]);

        if (memcmp(&chunk_header[0], "fmt ", 4) == 0) {
            u8 fmt[16];

            if (chunk_size < 16) {
                xil_printf("ERROR: chunk fmt invalido\r\n");
                f_close(&p->file);
                return -1;
            }

            fr = f_read(&p->file, fmt, 16, &br);
            if (fr != FR_OK || br != 16) {
                xil_printf("ERROR: no se pudo leer fmt\r\n");
                f_close(&p->file);
                return -1;
            }

            audio_format    = read_le16(&fmt[0]);
            channels        = read_le16(&fmt[2]);
            sample_rate     = read_le32(&fmt[4]);
            bits_per_sample = read_le16(&fmt[14]);

            found_fmt = 1;

            if (chunk_size > 16) {
                f_lseek(&p->file, f_tell(&p->file) + (chunk_size - 16));
            }

            if (chunk_size & 1) {
                f_lseek(&p->file, f_tell(&p->file) + 1);
            }
        }
        else if (memcmp(&chunk_header[0], "data", 4) == 0) {
            if (!found_fmt) {
                xil_printf("ERROR: data aparecio antes de fmt\r\n");
                f_close(&p->file);
                return -1;
            }

            p->data_start = f_tell(&p->file);
            p->data_size = chunk_size;
            found_data = 1;
        }
        else {
            f_lseek(&p->file, f_tell(&p->file) + chunk_size);

            if (chunk_size & 1) {
                f_lseek(&p->file, f_tell(&p->file) + 1);
            }
        }
    }

    xil_printf("WAV: format=%d, channels=%d, fs=%d, bits=%d, data=%d bytes\r\n",
               audio_format,
               channels,
               (int)sample_rate,
               bits_per_sample,
               (int)p->data_size);

    if (audio_format != 1) {
        xil_printf("ERROR: WAV no es PCM sin compresion\r\n");
        f_close(&p->file);
        return -1;
    }

    if (channels != EXPECTED_CHANNELS ||
        sample_rate != EXPECTED_SAMPLE_RATE ||
        bits_per_sample != EXPECTED_BITS) {

        xil_printf("ERROR: formato WAV no compatible.\r\n");
        xil_printf("Esperado: mono, 8000 Hz, 8-bit PCM unsigned.\r\n");
        f_close(&p->file);
        return -1;
    }

    f_lseek(&p->file, p->data_start);

    p->bytes_sent = 0;
    p->active = 1;
    p->eof_reached = 0;

    return 0;
}

// ================================================================
// Rellenar FIFO del buzzer con datos del WAV
// ================================================================

static void Audio_Update(AudioPlayer *p)
{
    if (!p->active) {
        return;
    }

    if (p->eof_reached) {
        if (Buzzer_GetFifoLevel() == 0) {
            xil_printf("Fin de cancion\r\n");
            Buzzer_Stop();
            f_close(&p->file);
            p->active = 0;
        }
        return;
    }

    u32 free_words = Buzzer_GetFreeWords();

    if (free_words == 0) {
        return;
    }

    u32 bytes_left = p->data_size - p->bytes_sent;

    if (bytes_left == 0) {
        p->eof_reached = 1;
        return;
    }

    u32 max_words_by_buffer = AUDIO_BUFFER_BYTES / 4;
    u32 words_to_write = free_words;

    if (words_to_write > max_words_by_buffer) {
        words_to_write = max_words_by_buffer;
    }

    u32 bytes_to_read = words_to_write * 4;

    if (bytes_to_read > bytes_left) {
        bytes_to_read = bytes_left;
    }

    if (bytes_to_read == 0) {
        return;
    }

    UINT br = 0;
    FRESULT fr = f_read(&p->file, audio_buffer, bytes_to_read, &br);

    if (fr != FR_OK) {
        xil_printf("ERROR: f_read fallo. FR=%d\r\n", fr);
        p->eof_reached = 1;
        return;
    }

    if (br == 0) {
        p->eof_reached = 1;
        return;
    }

    p->bytes_sent += br;

    /*
     * Empaquetado:
     * El VHDL reproduce primero bits 31:24,
     * luego 23:16,
     * luego 15:8,
     * luego 7:0.
     */
    for (u32 i = 0; i < br; i += 4) {
        u8 b0 = ApplyVolume(audio_buffer[i]);
        u8 b1 = (i + 1 < br) ? ApplyVolume(audio_buffer[i + 1]) : 0x80;
        u8 b2 = (i + 2 < br) ? ApplyVolume(audio_buffer[i + 2]) : 0x80;
        u8 b3 = (i + 3 < br) ? ApplyVolume(audio_buffer[i + 3]) : 0x80;

        u32 word = ((u32)b0 << 24)
                 | ((u32)b1 << 16)
                 | ((u32)b2 << 8)
                 | ((u32)b3);

        Buzzer_WriteAudioWord(word);
    }

    if (p->bytes_sent >= p->data_size) {
        p->eof_reached = 1;
    }
}

// ================================================================
// Debug de sample rate real
// ================================================================

static void Audio_DebugPrint(AudioPlayer *p)
{
    static XTime last_time = 0;
    static u32 last_samples = 0;
    static int initialized = 0;

    if (!p->active) {
        initialized = 0;
        return;
    }

    XTime now;
    XTime_GetTime(&now);

    if (!initialized) {
        last_time = now;
        last_samples = Buzzer_GetSamplesPlayed();
        initialized = 1;
        return;
    }

    if ((now - last_time) >= COUNTS_PER_SECOND) {
        u32 samples_now = Buzzer_GetSamplesPlayed();
        u32 delta_samples = samples_now - last_samples;

        u32 status = Buzzer_GetStatus();
        u32 fifo_level = Buzzer_GetFifoLevel();
        u32 fifo_free = Buzzer_GetFreeWords();

        xil_printf("DEBUG: samples/s=%lu, status=0x%08lx, fifo_level=%lu, fifo_free=%lu\r\n",
                   (unsigned long)delta_samples,
                   (unsigned long)status,
                   (unsigned long)fifo_level,
                   (unsigned long)fifo_free);

        last_time = now;
        last_samples = samples_now;
    }
}

// ================================================================
// Iniciar reproduccion desde cero
// ================================================================

static int Audio_Start(AudioPlayer *p, const char *filename)
{
    xil_printf("Iniciando cancion: %s\r\n", filename);

    if (p->active) {
        f_close(&p->file);
        p->active = 0;
    }

    Buzzer_Clear();

    if (Wav_OpenAndValidate(p, filename) != 0) {
        xil_printf("No se pudo iniciar audio\r\n");
        return -1;
    }

    /*
     * Prellenar FIFO antes de activar play.
     * Esto reduce underflow al inicio.
     */
    for (int i = 0; i < 16; i++) {
        Audio_Update(p);
    }

    Buzzer_Play();

    u32 status = Buzzer_GetStatus();
    u32 level = Buzzer_GetFifoLevel();
    u32 free_words = Buzzer_GetFreeWords();

    xil_printf("Reproduccion activada\r\n");
    xil_printf("STATUS=0x%08lx FIFO_LEVEL=%lu FIFO_FREE=%lu\r\n",
               (unsigned long)status,
               (unsigned long)level,
               (unsigned long)free_words);

    return 0;
}

// ================================================================
// Detener reproduccion y limpiar
// ================================================================

static void Audio_Stop(AudioPlayer *p)
{
    xil_printf("Deteniendo cancion\r\n");

    Buzzer_Stop();
    Buzzer_Clear();

    if (p->active) {
        f_close(&p->file);
        p->active = 0;
    }

    p->eof_reached = 0;
    p->bytes_sent = 0;
}

// ================================================================
// Leer botones
// ================================================================

static u32 ReadButtons(void)
{
    return XGpio_DiscreteRead(&BtnGpio, BTN_GPIO_CHANNEL) & 0x7;
}

// ================================================================
// MAIN
// ================================================================

int main(void)
{
    init_platform();

    int status;

    xil_printf("\r\n=== TEST BUZZER WAV AXI ===\r\n");

    status = XGpio_Initialize(&BtnGpio, BTN_GPIO_DEVICE_ID);
    if (status != XST_SUCCESS) {
        xil_printf("ERROR: XGpio_Initialize fallo\r\n");
        return XST_FAILURE;
    }

    XGpio_SetDataDirection(&BtnGpio, BTN_GPIO_CHANNEL, 0xFFFFFFFF);

    FRESULT fr = f_mount(&fatfs, "0:/", 1);
    if (fr != FR_OK) {
        xil_printf("ERROR: no se pudo montar SD. FR=%d\r\n", fr);
        return XST_FAILURE;
    }

    xil_printf("SD montada correctamente\r\n");
    xil_printf("Archivo esperado: %s\r\n", SONG_PATH);
    xil_printf("BTN0: iniciar/reiniciar\r\n");
    xil_printf("BTN1: detener\r\n");

    memset(&player, 0, sizeof(player));

    Buzzer_Clear();

    u32 prev_buttons = ReadButtons();

    while (1) {
        u32 buttons = ReadButtons();
        u32 rising_edges = buttons & (~prev_buttons);

        if (rising_edges & BTN_START_MASK) {
            Audio_Start(&player, SONG_PATH);
        }

        if (rising_edges & BTN_STOP_MASK) {
            Audio_Stop(&player);
        }

        prev_buttons = buttons;

        Audio_Update(&player);

        Audio_DebugPrint(&player);

        usleep(500);
    }

    cleanup_platform();

    return 0;
}
