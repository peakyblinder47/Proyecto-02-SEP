// Botones GPIO
#define BTN_GPIO_DEVICE_ID XPAR_AXI_GPIO_0_DEVICE_ID
#define BTN_GPIO_CHANNEL   1

#define BTN_START_MASK 0x01   // BTN0
#define BTN_STOP_MASK  0x02   // BTN1

#define GPIO0_DEVICE_ID XPAR_AXI_GPIO_1_DEVICE_ID

//Definiciones que servirán para el joystick
#define JOY_UMBRAL 200 //Umbral para detectar el movimiento del joystick
#define JOY_CENTER_X 512 //Valor central asociado al eje x
#define JOY_CENTER_Y 512 //Valor central asociado al eje y

static XGpio botones;
typedef enum{
	MENU,
	ESPERAR_BTN,
	INTRO,
	PLAY,
	END
} Estados_FSM;

static u32 LeerBotones(void)
{
    return XGpio_DiscreteRead(&botones, BTN_GPIO_CHANNEL) & 0x7;
}

static void Menu(void)
{
	xil_printf("Escoja la canción que desea:\n");
	xil_printf("[1] Chala Bit Chala\n");
	xil_printf("[2] Bit al sur\n");
	xil_printf("[3] Welcome to Vivado\n");
	xil_printf("[4] He Barrido el IP-Core\n");
	xil_printf("[5] Paint it Latch\n");
	xil_printf("[6] Byteco\n");
	xil_printf("[7] Never Gonna NAND you Up\n");
	xil_printf("[8] Attack on Timer\n");
	xil_printf("[9] Booster Fantasy\n");
	xil_printf("[10] We will byte you\n");
}

static const char* ElegirCancion(int num_cancion){

	if (num_cancion == 1){
	    return "DBZ8.WAV";
	}

	if (num_cancion == 2){
		return "PRIS8.WAV";
	}

	if (num_cancion == 3){
		return "GR8.WAV";
		}

	if (num_cancion == 4){
		return "LOS38.WAV";
		}

	if (num_cancion == 5){
		return "PAINT8.WAV";
		}

	if (num_cancion == 6){
		return "PSYC8.WAV";
		}

	if (num_cancion == 7){
		return "RICK8.WAV";
		}

	if (num_cancion == 8){
		return "SNK8.WAV";
		}

	if (num_cancion == 9){
		return "SSY8.WAV";
		}

	if (num_cancion == 10){
		return "WWRY8.WAV";
		}
	return NULL;
}

static void WAIT_BTN(void){
    // Espera mientras el botón NO esté presionado
	if (LeerBotones() & BTN_STOP_MASK) {
	    xil_printf("Cancelado. Volviendo al menu.\r\n");
	    ESTADO = MENU;
	}
    xil_printf("Reproduciendo canción...\n");

    // Espera a que se suelte (anti-rebote / evitar doble lectura)
    if (LeerBotones() & BTN_START_MASK) {
        xil_printf("Boton START detectado. Iniciando...\r\n");
        ESTADO = INTRO;
    }
}

extern int read_joyx();
extern int read_joyy();
int main(void)
{
    int status; //Estado de reproducción de la canción
    const char* SONG_PATH; //Ruta del archivo de música en la MicroSD
    int PATH_INDICE; //Con esta variable indicaremos qué canción tocar

    init_platform(); //Inicializa la plataforma

    xil_printf("=== Bienvenido a Guitar Zybo === \n");

    // Inicialización de los botones
    status = XGpio_Initialize(&botones, BTN_GPIO_DEVICE_ID);

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar AXI GPIO\r\n");
        return XST_FAILURE;
    }

    // Configuramos la entrada del bloque GPIO en Vivado
    XGpio_SetDataDirection(&botones, BTN_GPIO_CHANNEL, 0xFFFFFFFF);

    // Inicialización del audio (función en audio.h)
    //limpia el buzzer y carga el audio
    status = PLAY_SONG();

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: PLAY_SONG fallo\r\n");
        return XST_FAILURE;
    }

    status = XSpi_Init(&SpiInstance, SPI_DEVICE_ID);
    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar SPI del LCD\r\n");
        return XST_FAILURE;
    }

    status = XGpio_Initialize(&gpio0, GPIO0_DEVICE_ID);
    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar GPIO0 (LCD)\r\n");
        return XST_FAILURE;
    }

    LCD_Init(SCAN_DIR_DFT);

    //Movimiento del joystick
    int joyx_val = 0, joyy_val = 0;
    int joy_mov = 0;
    int prev_joystick_moved = 0;

    Estados_FSM ESTADO= MENU;
    while (1) {
    	//Máquina de estados para hacer correr el juego
    	switch(ESTADO){
    	case MENU:
    		//Enseńamos el menú de selección en la consola
			Menu();
			xil_printf("Ingrese la canción que desea escuchar: ");
			scanf("%d", &PATH_INDICE); //Input para el usuario
			xil_printf("Numero ingresado: %d\r\n", PATH_INDICE);
			xil_printf("Presione BTN0 para iniciar la cancion...\r\n");
			SONG_PATH = ElegirCancion(PATH_INDICE);
			//ElegirCancion es una función que asigna una canción a partir del input que recibe
			//el código

			//Si el número no es válido, no hacemos nada
			if (SONG_PATH == NULL){
				xil_printf("Por favor ingresar opción válida\n");
				continue;
			} else{
				ESTADO = ESPERAR_BTN; //Pero si song_path no es NULL, cambiamos de estado
				break;
			}
    	case ESPERAR_BTN:
    		WAIT_BTN(); //Esperamos que el botón se aprete para iniciar la canción
    		LCD_Clear(BLACK); //Fondo negro
    		ESTADO = INTRO;
    		break;

    	case INTRO:
    		GUI_INTRO(); //Imprimos la intro en la pantalla
    		usleep(2000000); // 2 segundos
    		GUI_TABLERO(); //Imprime el tablero del juego

    		//Empieza la canción con AUDIO_START

    		if (AUDIO_START(SONG_PATH) != XST_SUCCESS) {
				xil_printf("ERROR: no se pudo iniciar %s\r\n", SONG_PATH);
				ESTADO = MENU;
				break;
			}
    		//Mensaje para avisar que se reproduce la canción
			xil_printf("Reproduciendo el archivo: %s\r\n", SONG_PATH);
    		ESTADO = PLAY; //Estado de lógica del juego
    		break;
    	case PLAY:
    		prev_joystick_moved = joy_mov; //Actualizamos el valor "anterior"
    		//Lectura de los valores del joystick
			joyx_val = read_joyx(); //Rango entre 0 a 1023
			joyy_val = read_joyy(); //Mismo rango anterior
    		//Detección del movimiento en el joystick
			joy_mov = (abs(joyx_val-JOY_CENTER_X)>JOY_UMBRAL) ||
					(abs(joyy_val-JOY_CENTER_Y)>JOY_UMBRAL);


			if ((joy_mov)){
				// Encendida
				GUI_DrawRectangle(54, 80, 54+20, 80+20, YELLOW, DRAW_FULL, DOT_PIXEL_1X1);
			} else{
				GUI_DrawRectangle(54, 80, 54+20, 80+20, CYAN, DRAW_FULL, DOT_PIXEL_1X1);
			}

			// Actualizar audio
			ACTUALIZAR_AUDIO();
			// Verificar fin
			if (Audio_State() != PLAYING || (LeerBotones() & BTN_STOP_MASK))
				ESTADO = END;
			break;
    	case END:
    		STOP_AUDIO();
    		LCD_Clear(BLACK);
    		usleep(2000000); // 2 segundos
    		xil_printf("Volviendo al menú...\n");
    		ESTADO = MENU;
    		break;
    	}

    }

    cleanup_platform();

    return 0;
}
