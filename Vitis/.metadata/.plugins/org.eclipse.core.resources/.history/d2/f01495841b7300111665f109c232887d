#define BUZZER_BASEADDR XPAR_BUZZER_AXI_0_S00_AXI_BASEADDR

//Variables para controlar la "ganancia" del volumen
#define VOLUMEN_NUM 2
#define VOLUMEN_DEN 2

static FATFS sd; //sistema de archivos de la SD
static FIL cancion; // canción abierta

static u32 data_size = 0; //Guarda el número de bytes que tiene el WAV
static u32 byte_act = 44; //Servirá para saber en qué byte nos encontramos
// El audio suele partir en el byte 44

static u8 state = STOP_PLAYING;

void ACTUALIZAR_AUDIO(void);
void STOP_AUDIO(void);

//Limpia el IP-Core
// 0x00 es registro de control

static void Buzzer_Clear(void)
{
    Xil_Out32(BUZZER_BASEADDR + 0x00, 0);
    Xil_Out32(BUZZER_BASEADDR + 0x00, 0x06); //Limpia FIFO y errores
    Xil_Out32(BUZZER_BASEADDR + 0x00, 0);
}

static void Starter(void)
{
    Xil_Out32 (BUZZER_BASEADDR + 0x00, 0x01);
    //Activa la reproducción: pone el bit de play en 1
    //Activa la salida de la PWM
}

static void Stoper(void)
{
    Xil_Out32 (BUZZER_BASEADDR + 0X00 , 0X00);
    // Detiene el buzzer
}

static u8 Volumen(u8 muestra)
{
    int vol = ((int) muestra) - 128; //Centrado de la muestra
    vol = (vol * VOLUMEN_NUM)/VOLUMEN_DEN ; //aplicamos ganancia establecida

    if (vol > 123){
        vol = 123; //limitamos la seńal de volumen para evitar saturación
    }
    if (vol < -124){
        vol = -124;
    }

    return (u8)(vol + 128); //Vuelta al formato unsigned
    // (la muestra se aleja más del centro y se interpreta como más amplitud)

}

//Envía palabras de 32 bits al AXI
static u32 PackSamples(u8 b0, u8 b1, u8 b2, u8 b3)
{
    b0 = Volumen(b0);
    b1 = Volumen(b1);
    b2 = Volumen(b2);
    b3 = Volumen(b3);

    return ((u32)b0 << 24)
         | ((u32)b1 << 16)
         | ((u32)b2 << 8)
         | ((u32)b3);
}

int PLAY_SONG (void)
{
    FRESULT rc;

    rc = f_mount(&sd, "0:/", 1); //Accede a los archivos WAV
    if (rc != FR_OK) {
        xil_printf("ERROR: f_mount = %d\n", rc);
        return XST_FAILURE;
    } //Mensaje error

    Buzzer_Clear(); //Limpia el buzzer

    state = STOP_PLAYING;

    xil_printf("Audio Cargado! Listo para reproducir\n");

    return XST_SUCCESS;
}

int AUDIO_START(const char *filename)
{
    FRESULT rc;
    u8 size_bytes [4];
    UINT br; //bytes leídos

    if (state == PLAYING){
        STOP_AUDIO(); //Evita tener dos canciones abiertas a la vez
    }
    rc = f_open(&cancion, filename, FA_READ); //Abrimos el archivo de nombre
    //filename

    if (rc != FR_OK) {
        xil_printf("ERROR: f_open = %d\n", rc);
        return XST_FAILURE;
    }

    rc = f_lseek(&cancion, 40); // Mueve al byte 40 de

    if (rc != FR_OK) {
        xil_printf("ERROR: f_lseek 40 = %d\n", rc);
        f_close(&cancion);
        return XST_FAILURE;
    }

    rc = f_read(&cancion, size_bytes, 4, &br);
    //Lee 4 bytes desde el archivo cancion y los guarda en el arreglo size_bytes

    if (rc != FR_OK || br != 4) {
        xil_printf("ERROR: f_read size = %d\n", rc);
        f_close(&cancion);
        return XST_FAILURE;
    }

    data_size = ((u32)size_bytes[0])
          | ((u32)size_bytes[1] << 8)
          | ((u32)size_bytes[2] << 16)
          | ((u32)size_bytes[3] << 24);
    //convertimos el tamańo en un número entero

    byte_act = 44;
    rc = f_lseek(&cancion, byte_act);

    if (rc != FR_OK) {
        xil_printf("ERROR: f_lseek 44 = %d\n", rc);
        f_close(&cancion);
        return XST_FAILURE;
    }

    Buzzer_Clear();

    state = PLAYING;

    //Prellena la FIFO
    for (int i = 0; i < 64; i++) {
        ACTUALIZAR_AUDIO();
    }

    Starter();

    xil_printf("Reproduciendo %s, data_size=%lu\n", filename, data_size);
    //Imprimer en pantalla: Nombre del archivo y tamańo

    return XST_SUCCESS;
}

void ACTUALIZAR_AUDIO(void){
    FRESULT rc;
    UINT br;
    u8 b[4];

    if (state != PLAYING){
        return;
    }

    //Si el audio fue enviado, hay que esperar que la FIFO se vacíe
    if (byte_act >= 44 + data_size){
        if (Xil_In32(BUZZER_BASEADDR + 0X0C)==0){
            STOP_AUDIO();
            xil_printf("Terminó el audio!");
        }
        return;
    }
    //En cambio, si en la FIFO hay espacio, podemos guardar palabras
    u32 palabras = Xil_In32(BUZZER_BASEADDR + 0x04);
    for (int n = 0; n < 32 && palabras > 0 && byte_act < 44 + data_size; n++){
        rc = f_read(&cancion, b, 4, &br);

        if (rc != FR_OK) {
            xil_printf("ERROR: f_read audio = %d\r\n", rc);
            STOP_AUDIO();
            return;
        }

        if (br == 0) {
            byte_act = 44 + data_size;
            return;
        }

        byte_act += br;

        //si se leen menos de 4 bytes al final, se llena con silencio
        for (UINT i = br; i < 4; i++) {
            b[i] = 0x80;
        }

        //Enviamos la palabra formada con los bits del archivo
        u32 word_out = PackSamples(b[0], b[1], b[2], b[3]);

        //0x04 es escrito, entonces manda el audio al FIFO
        Xil_Out32(BUZZER_BASEADDR + 0x04, word_out);

        palabras--;
    }
}

//Este Stop_Audio es más una forma de reiniciar el audio
// La gracia será asociarlo a un botón que reinicie todo el sistema
void STOP_AUDIO (void){
    if (state == PLAYING){
        f_close(&cancion); //Cierra el archivo
    }

    Stoper(); //Detiene el Buzzer
    Buzzer_Clear(); //Limpia el Buzzer

    //Reinicia los parámetros
    data_size = 0;
    byte_act = 44;
    state = STOP_PLAYING;
}

u8 Audio_State(void)
{
    return state;
}
