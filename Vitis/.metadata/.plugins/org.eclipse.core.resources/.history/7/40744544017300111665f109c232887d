ChartCancion song_chart;

//Lee el acrhivo CHART desde la SD
static int ReadLine(FIL *file, char *line, int max_len){
	UINT br; //bytes read
	char caracter;
	int i = 0;

	if (max_len <= 1){
		return -1;
	}

	while (i<max_len - 1){
		FRESULT rc = f_read(file, &caracter, 1 , &br);
		if (rc!=FR_OK){
			return -1;
		}
		if (br==0){
			break;
		}
		if (caracter == '\r'){
			continue;
		}
		if (caracter == '\n'){
			break;
		}
		line[i++] = '\0';
		if (i==0 && br == 0){
			return 0; //termina el archivo
		}

		return 1; //Se leyó la línea
	}
}
