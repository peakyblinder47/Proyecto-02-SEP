void SensorTimer_Start(void)
{
    SensorTick = 0;
    SensorEnableTimer = 1;

    XTmrCtr_Reset(&AudioTimer, TIMER_CNTR_SENSOR);
    XTmrCtr_Start(&AudioTimer, TIMER_CNTR_SENSOR);
}

void SensorTimer_Stop(void)
{
    XTmrCtr_Stop(&AudioTimer, TIMER_CNTR_SENSOR);
    SensorEnableTimer = 0;
    SensorTick = 0;}
