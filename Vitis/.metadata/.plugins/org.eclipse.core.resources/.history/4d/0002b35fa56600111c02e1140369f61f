static void WAIT_BTN(void){
    // Espera mientras el botµn NO estÕ presionado
    while (!(LeerBotones() & BTN_START_MASK)) {
        usleep(500);
    }

    xil_printf("Reproduciendo canciµn...\n");

    // Espera a que se suelte (anti-rebote / evitar doble lectura)
    while (LeerBotones() & BTN_START_MASK) {
        usleep(500);
    }
}

static void ReproducirCancion(const char *song_path)
{

    if (AUDIO_START(song_path) != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo iniciar %s\r\n", song_path);
        return;
    }

    xil_printf("Reproduciendo el archivo: %s\r\n", song_path);

    //Si el
    while (Audio_State() == PLAYING) {
    	if (LeerBotones() & BTN_STOP_MASK){
    		xil_printf("Deteniendo canciµn...\n");
    		STOP_AUDIO();

    		while (LeerBotones() & BTN_STOP_MASK){
    			usleep(500);
    		}
    		break;
    	}

        //Actualiza la informaciµn de la FIFO en AXI
        ACTUALIZAR_AUDIO();

        usleep(500);
    }

    xil_printf("Volviendo al menº...\r\n");
}

int main(void)
{
    int status; //Estado de reproducciµn de la canciµn
    const char* SONG_PATH; //Ruta del archivo de mºsica en la MicroSD
    int PATH_INDICE; //Con esta variable indicaremos quÕ canciµn tocar

    init_platform(); //Inicializa la plataforma

    xil_printf("=== Bienvenido a Guitar Zybo === \n");

    // Inicializaciµn de los botones
    status = XGpio_Initialize(&botones, BTN_GPIO_DEVICE_ID);

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar AXI GPIO\r\n");
        return XST_FAILURE;
    }

    // Configuramos la entrada del bloque GPIO en Vivado
    XGpio_SetDataDirection(&botones, BTN_GPIO_CHANNEL, 0xFFFFFFFF);

    // Inicializaciµn del audio (funciµn en audio.h)
    //limpia el buzzer y carga el audio
    status = PLAY_SONG();

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: PLAY_SONG fallo\r\n");
        return XST_FAILURE;
    }

    status = XSpi_Init(&SpiInstance, SPI_DEVICE_ID);
    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar SPI del LCD\r\n");
        return XST_FAILURE;
    }

    status = XGpio_Initialize(&gpio1, GPIO0_DEVICE_ID);
    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar GPIO0 (LCD)\r\n");
        return XST_FAILURE;
    }

    LCD_Init(SCAN_DIR_DFT);
    while (1) {
    	Menu(); //Printea el menº en pantalla
    	xil_printf("Ingrese canciµn de preferencia: ");
    	scanf("%d", &PATH_INDICE); //Input para el usuario

    	SONG_PATH = ElegirCancion(PATH_INDICE);
    	//ElegirCancion es una funciµn que asigna una canciµn a partir del input que recibe
    	//el cµdigo
    	//Si el nºmero no es vÃlido, no hacemos nada
    	if (SONG_PATH == NULL){
    		xil_printf("Por favor ingresar opciµn vÃlida\n");
    		continue;
    	}

    	xil_printf("Escogiste la opciµn: %d\n", PATH_INDICE);

        // Espera el botµn con el cual partir la canciµn
    	WAIT_BTN();
    	//Reproduce la canciµn

    	LCD_Clear(BLACK);
    	usleep(2000000); // 2 segundos

    	GUI_INTRO();
    	usleep(2000000); // 2 segundos

    	LCD_Clear(BLACK);

    	ReproducirCancion(SONG_PATH);
    }

    cleanup_platform();

    return 0;
}
