	//Así usamos solo dos imágenes y después la rotamos
    const int W = 34;
    const int H = 34;

    for (int y = 0; y < H; y++) {
        for (int x = 0; x < W; x++) {

            int src_x;

            if (mirror) {
                src_x = W - 1 - x;
            } else {
                src_x = x;
            }

            COLOR pixel = music_pink_sprite[y][src_x];
            //La imagen tiene fondo verde, así que eso lo rechazamos
