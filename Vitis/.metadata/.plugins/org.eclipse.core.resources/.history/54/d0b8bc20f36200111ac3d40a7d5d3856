// Botones GPIO
#define BTN_GPIO_DEVICE_ID XPAR_AXI_GPIO_0_DEVICE_ID
#define BTN_GPIO_CHANNEL   1

#define BTN_START_MASK 0x01   // BTN0
#define BTN_STOP_MASK  0x02   // BTN1

static XGpio botones;

static u32 LeerBotones(void)
{
    return XGpio_DiscreteRead(&botones, BTN_GPIO_CHANNEL) & 0x7;
}

static void MostrarMenu(void)
{
	xil_printf("Escoja la canción que desea:\n");
	xil_printf("[1] Chala Bit Chala");
	xil_printf("[2] Bit al sur");
	xil_printf("[3] Welcome to Vivado");
	xil_printf("[4] He Barrido el IP-Core");
	xil_printf("[5] Paint it Latch");
	xil_printf("[6] Byteco");
	xil_printf("[7] Never Gonna NAND you Up");
	xil_printf("[8] Attack on Timer");
	xil_printf("[9] Booster Fantasy");
	xil_printf("[8] We will byte you");
}

int main(void)
{
    int status;
    char SONG_PATH;
    int PATH_INDICE;

    init_platform();

    xil_printf("\r\n=== TEST BUZZER AXI SIMPLE ===\r\n");

    // Inicializar AXI GPIO de botones
    status = XGpio_Initialize(&botones, BTN_GPIO_DEVICE_ID);

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: no se pudo inicializar AXI GPIO\r\n");
        return XST_FAILURE;
    }

    // Configurar GPIO como entrada
    XGpio_SetDataDirection(&botones, BTN_GPIO_CHANNEL, 0xFFFFFFFF);

    // Inicializar audio: monta SD y limpia el buzzer
    status = PLAY_SONG();

    if (status != XST_SUCCESS) {
        xil_printf("ERROR: PLAY_SONG fallo\r\n");
        return XST_FAILURE;
    }



    xil_printf("Archivo esperado: %s\r\n", SONG_PATH);
    xil_printf("BTN0: iniciar/reiniciar cancion\r\n");
    xil_printf("BTN1: detener cancion\r\n");

    u32 botones_previos = LeerBotones();

    while (1) {
        u32 botones_actuales = LeerBotones();

        // Detecta flanco de subida: botón recién presionado
        u32 flancos = botones_actuales & (~botones_previos);

        if (flancos & BTN_START_MASK) {
            xil_printf("BTN0 presionado: iniciar audio\r\n");
            AUDIO_START(SONG_PATH);
        }

        if (flancos & BTN_STOP_MASK) {
            xil_printf("BTN1 presionado: detener audio\r\n");
            STOP_AUDIO();
        }

        botones_previos = botones_actuales;

        // Mantiene alimentada la FIFO mientras el audio estį sonando
        ACTUALIZAR_AUDIO();

        usleep(500);
    }

    cleanup_platform();

    return 0;
}
